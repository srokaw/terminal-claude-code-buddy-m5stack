{
  "_comment": "Hook wiring for Claude Buddy (Phase 1 status hooks + Phase 2 PermissionRequest hook). Merge the \"hooks\" block below into ~/.claude/settings.json. If a \"hooks\" key already exists there, add these six keys alongside the existing ones. The command path must be absolute.",
  "hooks": {
    "SessionStart": [
      {"hooks": [{"type": "command", "command": "$HOME/terminal-claude-code-buddy-m5stack/hooks/buddy-hook.py"}]}
    ],
    "SessionEnd": [
      {"hooks": [{"type": "command", "command": "$HOME/terminal-claude-code-buddy-m5stack/hooks/buddy-hook.py"}]}
    ],
    "UserPromptSubmit": [
      {"hooks": [{"type": "command", "command": "$HOME/terminal-claude-code-buddy-m5stack/hooks/buddy-hook.py"}]}
    ],
    "Stop": [
      {"hooks": [{"type": "command", "command": "$HOME/terminal-claude-code-buddy-m5stack/hooks/buddy-hook.py"}]}
    ],
    "Notification": [
      {"hooks": [{"type": "command", "command": "$HOME/terminal-claude-code-buddy-m5stack/hooks/buddy-hook.py"}]}
    ],
    "PermissionRequest": [
      {"hooks": [{"type": "command", "command": "$HOME/terminal-claude-code-buddy-m5stack/hooks/buddy-permission-hook.py", "timeout": 180}]}
    ]
  }
}
